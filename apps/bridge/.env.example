# Robot connection (Phase 0b+)
SIM_MODE=stub                  # 'stub' | 'isaac' | 'mujoco_local' | 'real'
DDS_DOMAIN_ID=0
ROBOT_HOST=192.168.1.42         # Ubuntu Isaac Sim host (or G1 Jetson IP)

# Bridge transport (Phase 1+)
BRIDGE_WS_HOST=127.0.0.1
BRIDGE_WS_PORT=7077

# Voice (Phase 4)
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
WAKE_WORD_MODEL=hey_claude.tflite

# Logging
LOG_LEVEL=info
