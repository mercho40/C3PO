# Robot connection
SIM_MODE=stub                  # 'stub' | 'isaac' | 'real'
DDS_DOMAIN_ID=1                # unitree_sim_isaaclab defaults to domain 1
ROBOT_HOST=10.20.10.126        # Isaac Sim host IP, or G1 Jetson IP for SIM_MODE=real

# CycloneDDS C library install prefix (required at runtime — Python bindings dlopen libddsc.dylib).
# See apps/bridge/README.md for build instructions on macOS.
CYCLONEDDS_HOME=/Users/your-username/.local/cyclonedds-0.10.2

# Voice (Phase 4 — not used yet)
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
WAKE_WORD_MODEL=hey_claude.tflite

# Logging
LOG_LEVEL=info
