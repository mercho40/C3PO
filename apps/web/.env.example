PUBLIC_API_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-secret-here

# Optional. Host of the sim's teleimager camera servers (ports 60001-60003) for
# /live-camera. Defaults to the host serving the console (correct when the
# browser runs on the sim box). Set only to point at a different IP/hostname.
PUBLIC_SIM_CAM_HOST=
